# ─── Analytics Service — environment variables ────────────────────────────────
# Copy this file to .env and fill in real values before running.

PORT=8002

# Shared API key — must match ANALYTICS_SERVICE_API_KEY in the monolith .env
API_KEY=autosphere-internal-analytics-key

# Same MongoDB URI as the Node.js backend (read-only usage)
MONGODB_URI=mongodb://localhost:27017/AutoSphere_db
