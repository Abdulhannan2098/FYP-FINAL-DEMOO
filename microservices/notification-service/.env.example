# ─── Notification Service — environment variables ────────────────────────────
# Copy this file to .env and fill in real values before running.

PORT=8001

# Shared API key — must match NOTIFICATION_SERVICE_API_KEY in the monolith .env
API_KEY=autosphere-internal-notify-key

# SMTP (same values as the Node.js backend .env)
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USER=your_email@gmail.com
EMAIL_PASSWORD=your_gmail_app_password
EMAIL_FROM=noreply@autosphere.com

# Branding
BRAND_NAME=AutoSphere
FRONTEND_URL=http://localhost:5173
SUPPORT_EMAIL=support@autosphere.com
VENDOR_SUPPORT_EMAIL=vendor-support@autosphere.com
PRIMARY_COLOR=#991B1B
DARK_BG=#111827
CURRENCY=PKR
